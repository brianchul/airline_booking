meta {
  name: User login
  type: http
  seq: 2
}

post {
  url: {{URL}}/api/login
  body: json
  auth: none
}

body:json {
  {
    "email":"john.doe@example.com",
    "password": "password123"
  }
}

script:post-response {
  const accessToken = res.body.token;
  bru.setVar("access_token", accessToken);
  
}
